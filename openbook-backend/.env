# Pushing the env because all these are local URL's
# if you are trying to run this on your own machine your urls might be different please refer to the readme

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openbook
UPLOADS_DIR=uploads
OLLAMA_URL=http://localhost:11434

# replace with the ollama model you will be using
OLLAMA_MODEL=gemma4:e2b
